# Copy to ~/.config/yeelight/state.env and adjust to your LAN.
# This file is committed; the real one is NOT.

# Daemon bind
# YEELIGHT_BIND=127.0.0.1:8767

# Discovery - Yeelight M-SEARCH multicast (defaults are protocol constants)
# YEELIGHT_MULTICAST_ADDR=239.255.255.250
# YEELIGHT_MULTICAST_PORT=1982
# YEELIGHT_DISCOVER_TIMEOUT_S=2

# Refresh + re-discover cadences (seconds)
# YEELIGHT_REFRESH_INTERVAL_S=60
# YEELIGHT_DISCOVER_INTERVAL_S=600

# Broadcast fan-out concurrency cap (amendment A2)
# YEELIGHT_ALL_CONCURRENCY=16

# Logging + state
# YEELIGHT_LOG_LEVEL=INFO
# YEELIGHT_STATE_DIR=~/.config/yeelight
